<IfModule mod_rewrite.c>
    RewriteEngine On

    # 1) Forçar HTTPS
    # Redirecionar todo tráfego HTTP para HTTPS (301)
    RewriteCond %{HTTPS} off
    RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # 2) Padronizar www
    # Redirecionar www para não-www (301)
    RewriteCond %{HTTP_HOST} ^www\.(.*)$ [NC]
    RewriteRule ^(.*)$ https://%1/$1 [R=301,L]
</IfModule>

# 3) Página 404 personalizada
# Força o retorno à home, cobrindo rotas mortas por ser One Page
ErrorDocument 404 /index.html

# 4) Compressão gzip/deflate para performance
<IfModule mod_deflate.c>
    # Ativar mod_deflate para os assets de performance e layout
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE text/javascript
    AddOutputFilterByType DEFLATE text/plain
    AddOutputFilterByType DEFLATE text/xml
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/x-javascript
    AddOutputFilterByType DEFLATE application/json
    AddOutputFilterByType DEFLATE image/svg+xml
    AddOutputFilterByType DEFLATE font/ttf font/otf image/x-icon
</IfModule>

# 5) Cache de Navegador (MUITO IMPORTANTE - REGRAS DE CACHE-BUSTING)
<IfModule mod_expires.c>
    ExpiresActive On

    # Imagens e Mídias (jpg, png, webp, svg): 1 mês
    ExpiresByType image/jpg "access plus 1 month"
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/gif "access plus 1 month"
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType image/webp "access plus 1 month"
    ExpiresByType image/svg+xml "access plus 1 month"
    ExpiresByType image/x-icon "access plus 1 month"

    # CSS e JS: 1 semana
    ExpiresByType text/css "access plus 1 week"
    ExpiresByType application/javascript "access plus 1 week"
    ExpiresByType text/javascript "access plus 1 week"

    # HTML: 0 segundos
    ExpiresByType text/html "access plus 0 seconds"
</IfModule>

# Extensão de Cabeçalho forçado para garantir o NO-CACHE do HTML e regras de durabilidade
<IfModule mod_headers.c>
    # NUNCA gere cache para arquivos HTML, garanta que atualizações no código reflitam instantaneamente.
    <FilesMatch "\.(html|htm)$">
        Header set Cache-Control "max-age=0, no-cache, no-store, must-revalidate"
        Header set Pragma "no-cache"
        Header set Expires "Wed, 11 Jan 1984 05:00:00 GMT"
    </FilesMatch>

    # Cache Control público garantindo o cacheamento de mídias duradouras
    <FilesMatch "\.(jpg|jpeg|png|gif|webp|svg|ico)$">
        Header set Cache-Control "public, max-age=2592000"
    </FilesMatch>

    # Cache control para folha de estilos e script (semanais)
    <FilesMatch "\.(css|js)$">
        Header set Cache-Control "public, max-age=604800"
    </FilesMatch>
</IfModule>
